# ── Server ──
PORT=4000
NODE_ENV=development

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/farmdirect

# ── JWT ──
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=7d
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── Frontend (for CORS) ──
FRONTEND_URL=http://localhost:5173

# ── OTP ──
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# ── Email (optional, console fallback in dev) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@farmdirect.in

# ── SMS / Twilio (optional, console fallback in dev) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── S3 (optional, mock in dev) ──
# AWS_REGION=ap-south-1
# AWS_BUCKET=farmdirect-images
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
